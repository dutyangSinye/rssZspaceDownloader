# ========================================
# mteam-downloader (multi-tenant)
# ========================================

# ===== 应用服务配置 =====
HOST=0.0.0.0
PORT=5000
DEBUG=False
SECRET_KEY=change-me-in-production

# ===== 默认账号（首次初始化） =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=yangyang83
DEFAULT_TENANT_KEY=default
DEFAULT_TENANT_USERNAME=admin
DEFAULT_TENANT_PASSWORD=yangyang83

# ===== 数据库路径 =====
# 不填则默认 data/app.db
DB_PATH=data/app.db

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===== 默认租户初始化种子（首次建库时使用） =====
# 说明：这些值会在首次启动时写入 default 租户，之后请在 Web 页面中维护。
TRANSMISSION_HOST=http://localhost:9091
TRANSMISSION_USERNAME=
TRANSMISSION_PASSWORD=
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2

RSS_MOVIE_URL=
RSS_TV_URL=
RSS_ADULT_URL=

DOWNLOAD_DIR_MOVIE=/film
DOWNLOAD_DIR_TV=/tv
DOWNLOAD_DIR_ADULT=/av
