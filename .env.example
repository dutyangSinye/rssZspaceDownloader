# ========================================
# M-TEAM Downloader 配置文件
# ========================================
# 复制此文件为 .env 并填写你的配置

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=5000
DEBUG=False

# ===== Transmission BT 客户端配置 =====
TRANSMISSION_HOST=http://localhost:9091
TRANSMISSION_USERNAME=
TRANSMISSION_PASSWORD=
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2

# ===== M-TEAM RSS 配置 =====
RSS_MOVIE_URL=
RSS_TV_URL=
RSS_ADULT_URL=

DOWNLOAD_DIR_MOVIE=/film
DOWNLOAD_DIR_TV=/tv
DOWNLOAD_DIR_ADULT=/av

# ===== AI 配置 (OpenAI) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium

# ===== AI 配置 (Ollama 回退) =====
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7

# ===== 头条号配置 =====
TOUTIAO_COOKIE=
TOUTIAO_HEADLESS=False

# ===== 资讯采集关键词 =====
COLLECT_KEYWORDS=建筑机器人,智能建造,施工机器人,建筑自动化,建筑智能化

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

